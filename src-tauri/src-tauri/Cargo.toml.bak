[workspace]
members = [
    "rust-libs/error-system",
    "rust-libs/log-system",
    "rust-libs/python-bridge",
    "rust-libs/utils",
    "rust-libs/simple_motion",
    "rupy-libs/shape3",
    "rust-libs/event-system",
    "rust-libs/env-system",
    "rust-libs/vfs",
    "rust-libs/init-system",
    "rust-libs/lua-runtime",
    "rust-libs/mem-buffer",
    "rust-libs/cli-backend",
]

[package]
name = "solver"
version = "0.2.0"
description = "A problem visualizer and solver"
authors = ["you"]
edition = "2021"

[lib]
name = "solver_lib"
crate-type = ['staticlib', "cdylib", "rlib"]

[[bin]]
name = "solver"
path = "src/main.rs"

[profile.release-fast]
inherits = "release"
opt-level = 1
lto = "off"
codegen-units = 256
strip = "none"
panic = "unwind"

[dependencies]
tauri = { version = "2", features = [] }
tauri-plugin-opener = "2"
serde = { version = "1", features = ["derive"] }
serde_json = "1"
anyhow = "1"
log = "0.4"
uuid = { version = "1", features = ["v4"] }
sha2 = "0.10"
hex = "0.4"
rusqlite = { version = "0.32", features = ["bundled"] }
r2d2 = "0.8"
r2d2_sqlite = "0.25"
tokio = { version = "1", features = ["full"] }

# 内部 crates
error-system = { path = "rust-libs/error-system" }
log-system = { path = "rust-libs/log-system" }
python-bridge = { path = "rust-libs/python-bridge" }
utils = { path = "rust-libs/utils" }
event-system = { path = "rust-libs/event-system" }
env-system = { path = "rust-libs/env-system" }
vfs = { path = "rust-libs/vfs" }
init-system = { path = "rust-libs/init-system" }
lua-runtime = { path = "rust-libs/lua-runtime" }
mem-buffer = { path = "rust-libs/mem-buffer" }
cli-backend = { path = "rust-libs/cli-backend" }

# Tauri 插件
tauri-plugin-window-enhance = { path = "plugins/window_enhance" }
tauri-plugin-dialog = "2"
tauri-plugin-log = "2"

[build-dependencies]
tauri-build = { version = "2", features = [] }
