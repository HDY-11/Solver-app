{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "solver",
  "version": "0.2.0",
  "identifier": "com.tauri-app.solver.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist",
    "beforeBundleCommand": "powershell -Command \"Get-ChildItem -Recurse -Directory -Include 'test','tests','idlelib','turtledemo','ensurepip','distutils' -Path '.venv/Lib' | Remove-Item -Recurse -Force -ErrorAction SilentlyContinue\""
  },
  "app": {
    "windows": [
      {
        "title": "solver",
        "width": 800,
        "height": 600,
        "decorations": false,
        "dragDropEnabled": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "resources": {
      "../.venv/Lib/": "Lib/",
      "../.venv/Scripts/DLLs/": "DLLs/",
      "../dlls/": "./"
    },
    "windows": {
      "nsis": {
        "compression": "zlib"
      }
    },
    "targets": ["nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
